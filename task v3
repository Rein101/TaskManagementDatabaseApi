    question = effective_q
    turn: dict = {"question": question}

    with st.spinner("Thinking…"):
        try:
            # ── Call the COST_ANALYST named agent ─────────────────────────
            resp = call_agent(question)
            sql, agent_text = parse_agent_response(resp)
            turn["agent_text"] = agent_text

            if sql:
                turn["sql"] = sql
                df = run_query(sql)
                turn["df"]         = df
                turn["chart_type"] = detect_chart(df)
                if st.session_state["show_narr"] and not df.empty:
                    turn["narrative"] = generate_narrative(question, df)
            else:
                # Agent answered in natural language without runnable SQL
                # (e.g. clarifying question, explanation)
                turn["sql"]        = None
                turn["df"]         = None
                turn["chart_type"] = "table"

        except Exception as exc:
            turn["error"] = str(exc)

    st.session_state["history"].append(turn)
    st.rerun()
