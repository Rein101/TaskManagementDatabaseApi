def _get_auth_token() -> str:
    """OAuth bearer token — only available in Container Runtime."""
    with open("/snowflake/session/token", "r") as f:
        return f.read().strip()


def _get_host() -> str:
    return os.getenv("SNOWFLAKE_HOST", "")


# ── SSE PARSER ────────────────────────────────────────────────────────────────
def _parse_sse(sse_text: str) -> dict:
    """
    Parse a Server-Sent Events stream into a single assembled message dict.
    The Cortex Agents named endpoint returns SSE even with stream=False.
    """
    blocks: dict[int, dict] = {}

    for raw_line in sse_text.splitlines():
        raw_line = raw_line.strip()
        if not raw_line.startswith("data:"):
            continue
        payload = raw_line[5:].strip()
        if payload in ("[DONE]", ""):
            continue
        try:
            ev = json.loads(payload)
        except Exception:
            continue

        etype = ev.get("type", "")

        if etype == "content_block_start":
            idx = ev.get("index", 0)
            blocks[idx] = dict(ev.get("content_block", {}))

        elif etype == "content_block_delta":
            idx   = ev.get("index", 0)
            delta = ev.get("delta", {})
            if idx not in blocks:
                blocks[idx] = {}
            dtype = delta.get("type", "")
            if dtype == "text_delta":
                blocks[idx]["text"] = blocks[idx].get("text", "") + delta.get("text", "")
            elif dtype == "input_json_delta":
                # Tool input arrives in pieces — accumulate
                blocks[idx]["_raw_input"] = (
                    blocks[idx].get("_raw_input", "") + delta.get("partial_json", "")
                )

        elif etype == "content_block_stop":
            idx = ev.get("index", 0)
            if idx in blocks and "_raw_input" in blocks[idx]:
                try:
                    blocks[idx]["input"] = json.loads(blocks[idx]["_raw_input"])
                except Exception:
                    blocks[idx]["input"] = {}
                del blocks[idx]["_raw_input"]

    content = [blocks[i] for i in sorted(blocks.keys())]
    return {"message": {"role": "assistant", "content": content}}


# ── AGENT CALL ────────────────────────────────────────────────────────────────
def call_agent(question: str) -> dict:
    """
    Call the named COST_ANALYST Cortex Agent.

    Critical rules for named agents:
    - Do NOT include "model" — the agent has its model configured in Snowflake.
    - Do NOT include "tools" — the agent's tools (Cortex Analyst, Search, etc.)
      are pre-configured. Sending "tools": [] kills them all.
    - Multi-turn: send full conversation history in "messages".
    - The response is SSE (text/event-stream) regardless of stream setting,
      so parse it as SSE.
    """
    messages = list(st.session_state.get("agent_messages", []))
    messages.append({"role": "user", "content": question})

    body = {
        "messages": messages,
        # NO "model" — agent is pre-configured
        # NO "tools" — named agent's tools are already attached
        "stream": False,
    }

    token = _get_auth_token()
    host  = _get_host()
    url   = f"https://{host}{AGENT_ENDPOINT}"
    headers = {
        "Authorization": f"Bearer {token}",
        "Content-Type":  "application/json",
        "Accept":        "application/json",
        "X-Snowflake-Authorization-Token-Type": "OAUTH",
    }

    r = requests.post(url, json=body, headers=headers, timeout=120)
    if r.status_code != 200:
        raise RuntimeError(f"Agent {r.status_code}: {r.text[:600]}")

    # Named agent endpoint ALWAYS returns SSE even when stream=False
    content_type = r.headers.get("content-type", "")
    if "event-stream" in content_type:
        resp = _parse_sse(r.text)
    else:
        try:
            resp = r.json()
        except Exception:
            # Fallback: treat as SSE anyway
            resp = _parse_sse(r.text)

    # Store full assistant turn for multi-turn context
    if resp.get("message"):
        messages.append(resp["message"])
        st.session_state["agent_messages"] = messages

    return resp


# ── RESPONSE PARSER ───────────────────────────────────────────────────────────
def _extract_sql(text: str) -> str | None:
    """Try to pull a SQL statement out of arbitrary text."""
    if not text:
        return None
    # Fenced code block  ```sql ... ```
    m = re.search(r"```(?:sql)?\s*(SELECT\b.+?)\s*```", text, re.S | re.I)
    if m:
        return m.group(1).strip()
    # Bare SELECT … ; statement
    m = re.search(r"(SELECT\b.+?;)", text, re.S | re.I)
    if m:
        return m.group(1).strip()
    # SELECT without trailing semicolon (grab until double newline or end)
    m = re.search(r"(SELECT\b.+?)(?:\n\n|\Z)", text, re.S | re.I)
    if m:
        return m.group(1).strip()
    return None


def parse_agent_response(resp: dict) -> tuple[str | None, str]:
    """
    Extract (sql, narrative_text) from a Cortex Agent response.

    The agent response content blocks can be:
      {"type": "text",        "text": "..."}          ← narrative
      {"type": "sql",         "statement": "..."}      ← Cortex Analyst proxied format
      {"type": "tool_use",    "input": {...}}           ← agent called a tool
      {"type": "tool_result", "content": [...]}         ← tool returned data/SQL
    """
    sql: str | None = None
    texts: list[str] = []

    content = resp.get("message", {}).get("content", [])

    # Some agent builds return content as a plain string
    if isinstance(content, str):
        texts.append(content)
        sql = _extract_sql(content)
        return sql, content

    for block in content:
        if not isinstance(block, dict):
            continue
        btype = block.get("type", "")

        # ── Narrative text ─────────────────────────────────────────────────
        if btype == "text":
            t = block.get("text", "").strip()
            if t:
                texts.append(t)

        # ── Cortex Analyst format proxied through agent ────────────────────
        elif btype == "sql":
            if not sql:
                sql = block.get("statement", "").strip()

        # ── Agent called a tool (e.g. Cortex Analyst) ─────────────────────
        elif btype == "tool_use":
            inp = block.get("input", {})
            if isinstance(inp, dict):
                # Cortex Analyst tool input sometimes includes the generated SQL
                for key in ("sql", "statement", "query"):
                    if key in inp and not sql:
                        candidate = inp[key]
                        if isinstance(candidate, str) and "SELECT" in candidate.upper():
                            sql = candidate.strip()
                            break

        # ── Tool result — contains SQL and/or structured data ──────────────
        elif btype == "tool_result":
            tc = block.get("content", [])
            if isinstance(tc, str):
                if not sql:
                    sql = _extract_sql(tc)
            elif isinstance(tc, list):
                for item in tc:
                    if not isinstance(item, dict):
                        continue
                    # JSON payload (structured tool result)
                    json_payload = item.get("json", {})
                    if isinstance(json_payload, dict):
                        for key in ("sql", "statement"):
                            if key in json_payload and not sql:
                                sql = json_payload[key]
                    # Text payload
                    raw_text = item.get("text", "")
                    if raw_text and not sql:
                        sql = _extract_sql(raw_text)

    # Last resort: scan narrative for embedded SQL
    if not sql:
        sql = _extract_sql("\n".join(texts))

    return sql, "\n".join(texts).strip()


