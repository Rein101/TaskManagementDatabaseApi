# ─── CORTEX ANALYST ──────────────────────────────────────────────────────────
def call_analyst(filtered_question: str) -> dict:
    body = {
        "messages": [{
            "role": "user",
            "content": [{"type": "text", "text": filtered_question}],
        }],
        "semantic_view": SEMANTIC_MODEL_FILE,
    }
    try:
        import _snowflake
        resp = _snowflake.send_snow_api_request(
            "POST", ANALYST_ENDPOINT, {}, {}, body, {}, 45000
        )
        if resp.get("status") != 200:
            raise RuntimeError(
                f"Cortex Analyst {resp.get('status')}: {resp.get('content', '(no detail)')}"
            )
        return json.loads(resp["content"])
    except ImportError:
        conn = session.connection
        token = conn.rest.token
        host = conn.host
        url = f"https://{host}{ANALYST_ENDPOINT}"
        headers = {
            "Authorization": f'Snowflake Token="{token}"',
            "Content-Type": "application/json",
        }
        r = requests.post(url, json=body, headers=headers, timeout=60)
        if r.status_code != 200:
            raise RuntimeError(f"Cortex Analyst {r.status_code}: {r.text[:500]}")
        return r.json()


def parse_analyst_response(resp: dict) -> tuple[str | None, str]:
    sql, texts = None, []
    for block in resp.get("message", {}).get("content", []):
        if block.get("type") == "sql":
            sql = block.get("statement", "").strip()
        elif block.get("type") == "text":
            texts.append(block.get("text", ""))
    return sql, " ".join(texts).strip()


def enforce_filters(sql: str, filters: dict) -> str:
    """
    Replace the fact table reference in Analyst-generated SQL with a pre-filtered
    CTE that enforces mandatory L1 dimension filters.
    """
    if not sql:
        return sql

    acct_l1 = filters.get("account_l1", ["OPEX"])
    entity_l1 = filters.get("entity_l1", [])
    cc_l1 = filters.get("cost_center_l1", [])
    fa_l1 = filters.get("func_area_l1", [])
    pc_l1 = filters.get("profit_center_l1", [])
    versions = filters.get("versions", [])

    joins: list[str] = []
    wheres: list[str] = []

    if versions:
        in_list = ", ".join(f"'{v}'" for v in versions)
        wheres.append(f"f.VERSION IN ({in_list})")
    else:
        wheres.append("f.VERSION = 'Actual'")

    if acct_l1:
        joins.append(
            "JOIN ACC_PRD.MASTERDATA.VW_JEDOX_MASTER_DATA_ACCOUNT __acct "
            "ON f.ACCOUNT = __acct.ACCOUNT_CODE"
        )
        in_list = ", ".join(f"'{v}'" for v in acct_l1)
        wheres.append(f"__acct.ACCOUNT_LEVEL_1 IN ({in_list})")

    if entity_l1:
        joins.append(
            "JOIN ACC_PRD.MASTERDATA.VW_JEDOX_MASTER_DATA_ENTITY __ent "
            "ON f.ENTITY = __ent.ENTITY_CODE"
        )
        in_list = ", ".join(f"'{v}'" for v in entity_l1)
        wheres.append(f"__ent.ENTITY_LEVEL_1 IN ({in_list})")

    if cc_l1:
        joins.append(
            "JOIN ACC_PRD.MASTERDATA.VW_JEDOX_MASTER_DATA_COST_CENTER __cc "
            "ON f.COST_CENTER = __cc.COST_CENTER_CODE"
        )
        in_list = ", ".join(f"'{v}'" for v in cc_l1)
        wheres.append(f"__cc.COST_CENTER_LEVEL_1 IN ({in_list})")

    if fa_l1:
        joins.append(
            "JOIN ACC_PRD.MASTERDATA.VW_JEDOX_MASTER_DATA_FUNC_AREA __fa "
            "ON f.FUNCTIONAL_AREA = __fa.FUNC_AREA_CODE"
        )
        in_list = ", ".join(f"'{v}'" for v in fa_l1)
        wheres.append(f"__fa.FUNC_AREA_LEVEL_1 IN ({in_list})")

    if pc_l1:
        joins.append(
            "JOIN ACC_PRD.MASTERDATA.VW_JEDOX_MASTER_DATA_PROFIT_CENTER __pc "
            "ON f.PROFIT_CENTER = __pc.PROFIT_CENTER_CODE"
        )
        in_list = ", ".join(f"'{v}'" for v in pc_l1)
        wheres.append(f"__pc.PROFIT_CENTER_LEVEL_1 IN ({in_list})")

    if not wheres:
        return sql

    join_block = "\n    ".join(joins)
    where_block = "\n      AND ".join(wheres)

    filtered_cte = (
        f"__opex_filtered AS (\n"
        f"    SELECT f.*\n"
        f"    FROM EDW_DEV.WH.VW_JEDOX_DATA_OPEX f\n"
        f"    {join_block}\n"
        f"    WHERE {where_block}\n"
        f")"
    )

    fact_pattern = re.compile(r"\bEDW_DEV\.WH\.VW_JEDOX_DATA_OPEX\b", re.I)

    if not fact_pattern.search(sql):
        return sql

    replaced = fact_pattern.sub("__opex_filtered", sql)

    if re.match(r"\s*WITH\b", replaced, re.I):
        replaced = re.sub(r"(?i)^\s*WITH\s+", "", replaced, count=1)
        return f"WITH {filtered_cte},\n{replaced}"
    else:
        return f"WITH {filtered_cte}\n{replaced}"


