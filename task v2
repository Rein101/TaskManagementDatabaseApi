@st.cache_data(ttl=600)
def get_hierarchy_values(dimension: str, level_idx: int, parent_selections: dict) -> list[str]:
    spec = _DIM_HIERARCHY.get(dimension)
    if not spec or level_idx >= len(spec["levels"]):
        return []
    table = spec["table"]
    col = spec["levels"][level_idx]
    wheres = []
    for i in range(level_idx):
        parent_vals = parent_selections.get(i, [])
        if parent_vals:
            in_list = ", ".join(f"'{v}'" for v in parent_vals)
            wheres.append(f'{spec["levels"][i]} IN ({in_list})')
    where_clause = f"WHERE {col} IS NOT NULL AND {col} != ''"
    if wheres:
        where_clause += " AND " + " AND ".join(wheres)
    try:
        df = session.sql(f"SELECT DISTINCT {col} AS VAL FROM {table} {where_clause} ORDER BY 1").to_pandas()
        return df["VAL"].tolist()
    except Exception:
        return []


