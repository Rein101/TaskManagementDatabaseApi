# ── HIERARCHY ENRICHMENT (pivot-style output) ─────────────────────────────────
@st.cache_data(ttl=600)
def load_dim_hierarchy_lookup(dim: str) -> pd.DataFrame:
    """Full level table for a dimension — used to enrich result tables."""
    spec = _DIM_HIERARCHY.get(dim)
    if not spec:
        return pd.DataFrame()
    levels = ", ".join(spec["levels"])
    try:
        return session.sql(
            f"SELECT DISTINCT {spec['code_col']}, {levels} FROM {spec['table']}"
        ).to_pandas()
    except Exception:
        return pd.DataFrame()


_FACT_TO_DIM = {
    "ACCOUNT":          ("account",         "ACCOUNT_CODE"),
    "COST_CENTER":      ("cost_center",      "COST_CENTER_CODE"),
    "ENTITY":           ("entity",           "ENTITY_CODE"),
    "FUNCTIONAL_AREA":  ("functional_area",  "FUNC_AREA_CODE"),
    "PROFIT_CENTER":    ("profit_center",    "PROFIT_CENTER_CODE"),
}


def enrich_with_hierarchy(df: pd.DataFrame) -> pd.DataFrame:
    """
    For each dimension code column found in the result, left-join all hierarchy
    level columns so the download is pivot-ready: L1 → L2 → L3 → L4 → Code → Amounts.
    Only adds columns not already present — never duplicates.
    """
    if df.empty:
        return df
    result   = df.copy()
    col_upper = {c.upper(): c for c in result.columns}

    for fact_col_upper, (dim, code_col) in _FACT_TO_DIM.items():
        if fact_col_upper not in col_upper:
            continue
        spec = _DIM_HIERARCHY.get(dim)
        if not spec:
            continue
        new_levels = [lv for lv in spec["levels"] if lv not in result.columns]
        if not new_levels:
            continue
        lookup = load_dim_hierarchy_lookup(dim)
        if lookup.empty:
            continue
        actual_col = col_upper[fact_col_upper]
        lookup = lookup.rename(columns={code_col: actual_col})
        result = result.merge(
            lookup[[actual_col] + new_levels].drop_duplicates(),
            on=actual_col, how="left"
        )
        # Reorder: put hierarchy levels immediately after the code column
        all_cols  = result.columns.tolist()
        code_pos  = all_cols.index(actual_col)
        hier_cols = [c for c in new_levels if c in all_cols]
        rest      = [c for c in all_cols if c not in hier_cols]
        result    = result[rest[:code_pos+1] + hier_cols + rest[code_pos+1:]]

    return result


