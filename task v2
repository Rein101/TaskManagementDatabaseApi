# ─── FISCAL PERIOD HELPERS ────────────────────────────────────────────────────
def fiscal_years() -> list[str]:
    y = date.today().year
    return [str(y - 2), str(y - 1), str(y)]

def fiscal_quarters() -> list[str]:
    return ["Q1", "Q2", "Q3", "Q4"]

def fiscal_months() -> list[str]:
    return ["Jan","Feb","Mar","Apr","May","Jun",
            "Jul","Aug","Sep","Oct","Nov","Dec"]

def default_year() -> str:
    return str(date.today().year)

def default_quarter() -> str:
    # FY starts October: (month-10)%12 shifts Oct→0, Nov→1 … Sep→11
    shifted = (date.today().month - 10) % 12
    return f"Q{shifted // 3 + 1}"

def default_month() -> str:
    return date.today().strftime("%b")

def available_months_for_quarters(selected_quarters: list[str]) -> list[str]:
    """Return month abbreviations that belong to the selected quarters."""
    if not selected_quarters:
        return fiscal_months()
    months = []
    for q in ["Q1", "Q2", "Q3", "Q4"]:
        if q in selected_quarters:
            months.extend(_QUARTER_MONTH_ABBRS[q])
    return months

def compute_periods(
    sel_years: list[str],
    sel_quarters: list[str],
    sel_months: list[str],
) -> list[str]:
    """
    Convert UI selections → sorted YYYYMM strings.
    sel_months is an optional within-quarter filter; empty = all months.
    """
    if not sel_years:
        return []
    quarters  = sel_quarters if sel_quarters else ["Q1", "Q2", "Q3", "Q4"]
    month_nums = {_MONTH_TO_NUM[m] for m in sel_months} if sel_months else None

    periods: set[str] = set()
    for fy_str in sel_years:
        fy = int(fy_str)
        for q in quarters:
            yr_offset, q_months = _QUARTER_CALENDAR[q]
            cal_year = fy + yr_offset
            for m in q_months:
                if month_nums is None or m in month_nums:
                    periods.add(f"{cal_year}-{m:02d}")
    return sorted(periods)


# ─── DIMENSION FILTER LOADER ──────────────────────────────────────────────────
@st.cache_data(ttl=600)
def get_filter_values(dimension: str) -> list[str]:
    """Load distinct code values from a dimension master view."""
    if dimension not in _DIM_TABLES:
        return []
    table, col = _DIM_TABLES[dimension]
    try:
        df = session.sql(f"""
            SELECT DISTINCT {col} AS VAL
            FROM {table}
            WHERE {col} IS NOT NULL
            ORDER BY 1
        """).to_pandas()
        return df["VAL"].tolist()
    except Exception:
        return []


# ─── HIERARCHY KEYWORD DETECTION ─────────────────────────────────────────────
_ACCOUNT_HIERARCHY_LEVELS = ["ACCOUNT_LEVEL_1", "ACCOUNT_LEVEL_2", "ACCOUNT_LEVEL_3", "ACCOUNT_LEVEL_4"]

@st.cache_data(ttl=600)
def load_account_hierarchy() -> pd.DataFrame:
    try:
        return session.sql(
            "SELECT DISTINCT ACCOUNT_LEVEL_1, ACCOUNT_LEVEL_2, ACCOUNT_LEVEL_3, ACCOUNT_LEVEL_4, ACCOUNT_CODE "
            "FROM ACC_PRD.MASTERDATA.VW_JEDOX_MASTER_DATA_ACCOUNT ORDER BY 1"
        ).to_pandas()
    except Exception:
        return pd.DataFrame()


def resolve_account_keyword(keyword: str) -> dict:
    df = load_account_hierarchy()
    if df.empty:
        return {}
    kw_lower = keyword.lower().strip()
    for level_idx in range(3, -1, -1):
        col = _ACCOUNT_HIERARCHY_LEVELS[level_idx]
        if col not in df.columns:
            continue
        for val in df[col].dropna().unique():
            if val and kw_lower in str(val).lower():
                return {"level_idx": level_idx, "level_col": col, "matched_value": str(val)}
    return {}


_KEYWORD_HINTS = [
    "travel", "t&e", "software", "consulting", "salary", "bonus",
    "depreciation", "amortization", "facilities", "equipment", "rent",
    "training", "recruitment", "insurance", "utilities", "communications",
    "employee", "variable", "fixed", "opex", "compensation", "stock",
    "contractor", "marketing", "legal", "healthcare", "patent",
    "conference", "promotion", "logistics", "maintenance", "bad debt",
    "commissions", "fees", "allocation", "services", "subscriptions",
]


def detect_account_keywords(text: str) -> list[dict]:
    matches = []
    text_lower = text.lower()
    for kw in _KEYWORD_HINTS:
        if kw in text_lower:
            result = resolve_account_keyword(kw)
            if result and not any(m["matched_value"] == result["matched_value"] for m in matches):
                matches.append(result)
    return matches


# ─── FILTER → QUESTION BUILDER ────────────────────────────────────────────────
def build_filtered_question(question: str, filters: dict) -> str:
    """
    Prefix the user question with mandatory context so Cortex Analyst
    restricts its generated SQL. Includes hierarchy keyword detection.
    """
    parts: list[str] = []

    currency_map = {"EUR": "VAL_EUR", "USD": "VAL_USD_INI", "LC": "VAL_LC", "DC": "VAL_EUR_NORM"}
    currency = filters.get("currency", "EUR")
    val_col = currency_map.get(currency, "VAL_EUR")
    parts.append(f"Use {val_col} as the value/amount column for all aggregations (currency: {currency}).")

    hierarchy_matches = detect_account_keywords(question)
    if hierarchy_matches:
        for m in hierarchy_matches:
            level_name = m["level_col"].replace("_", " ").title()
            parts.append(
                f"IMPORTANT: The user is asking about '{m['matched_value']}' which is found at "
                f"{level_name} in the account hierarchy. "
                f"To filter for this, JOIN the fact table's ACCOUNT column to "
                f"ACC_PRD.MASTERDATA.VW_JEDOX_MASTER_DATA_ACCOUNT.ACCOUNT_CODE "
                f"and filter WHERE {m['level_col']} = '{m['matched_value']}'. "
                f"Include ACCOUNT_LEVEL_1, ACCOUNT_LEVEL_2, ACCOUNT_LEVEL_3, ACCOUNT_LEVEL_4 in the output."
            )

    acct_l1 = filters.get("account_l1", ["OPEX"])
    if acct_l1:
        in_list = ", ".join(f"'{v}'" for v in acct_l1)
        parts.append(
            f"MANDATORY FILTER: Only include rows where ACCOUNT_LEVEL_1 IN ({in_list}). "
            f"JOIN fact.ACCOUNT = ACC_PRD.MASTERDATA.VW_JEDOX_MASTER_DATA_ACCOUNT.ACCOUNT_CODE "
            f"and apply WHERE ACCOUNT_LEVEL_1 IN ({in_list})."
        )

    entity_l1 = filters.get("entity_l1", [])
    if entity_l1:
        in_list = ", ".join(f"'{v}'" for v in entity_l1)
        parts.append(
            f"Entity filter: JOIN fact.ENTITY = ACC_PRD.MASTERDATA.VW_JEDOX_MASTER_DATA_ENTITY.ENTITY_CODE "
            f"WHERE ENTITY_LEVEL_1 IN ({in_list})."
        )

    cc_l1 = filters.get("cost_center_l1", [])
    if cc_l1:
        in_list = ", ".join(f"'{v}'" for v in cc_l1)
        parts.append(
            f"Cost Center filter: JOIN fact.COST_CENTER = ACC_PRD.MASTERDATA.VW_JEDOX_MASTER_DATA_COST_CENTER.COST_CENTER_CODE "
            f"WHERE COST_CENTER_LEVEL_1 IN ({in_list})."
        )

    fa_l1 = filters.get("func_area_l1", [])
    if fa_l1:
        in_list = ", ".join(f"'{v}'" for v in fa_l1)
        parts.append(
            f"Functional Area filter: JOIN fact.FUNCTIONAL_AREA = ACC_PRD.MASTERDATA.VW_JEDOX_MASTER_DATA_FUNC_AREA.FUNC_AREA_CODE "
            f"WHERE FUNC_AREA_LEVEL_1 IN ({in_list})."
        )

    pc_l1 = filters.get("profit_center_l1", [])
    if pc_l1:
        in_list = ", ".join(f"'{v}'" for v in pc_l1)
        parts.append(
            f"Profit Center filter: JOIN fact.PROFIT_CENTER = ACC_PRD.MASTERDATA.VW_JEDOX_MASTER_DATA_PROFIT_CENTER.PROFIT_CENTER_CODE "
            f"WHERE PROFIT_CENTER_LEVEL_1 IN ({in_list})."
        )

    periods = filters.get("periods", [])
    if periods:
        preview = ", ".join(periods[:8])
        more = f" (+{len(periods)-8} more)" if len(periods) > 8 else ""
        parts.append(f"TIME column filter (YYYY-MM format): TIME IN ({preview}{more})")

    versions = filters.get("versions", [])
    if versions:
        in_list = ", ".join(f"'{v}'" for v in versions)
        parts.append(f"VERSION filter: VERSION IN ({in_list})")
    else:
        parts.append("VERSION filter: Default to VERSION = 'Actual' unless user explicitly mentions budget or forecast.")

    if not parts:
        return question

    ctx = "MANDATORY CONTEXT - Apply ALL these conditions to the SQL query:\n" + "\n".join(
        f"  * {p}" for p in parts
    )
    return f"{ctx}\n\nQuestion: {question}"


