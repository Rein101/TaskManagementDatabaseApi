# ── ACCOUNT HIERARCHY KEYWORD DETECTION (from task_v2) ───────────────────────
_ACCOUNT_HIERARCHY_LEVELS = ["ACCOUNT_LEVEL_1","ACCOUNT_LEVEL_2","ACCOUNT_LEVEL_3","ACCOUNT_LEVEL_4"]

@st.cache_data(ttl=600)
def load_account_hierarchy() -> pd.DataFrame:
    """Load the full account hierarchy once and cache it."""
    try:
        return session.sql(
            "SELECT DISTINCT ACCOUNT_LEVEL_1, ACCOUNT_LEVEL_2, ACCOUNT_LEVEL_3, "
            "ACCOUNT_LEVEL_4, ACCOUNT_CODE "
            "FROM ACC_PRD.MASTERDATA.VW_JEDOX_MASTER_DATA_ACCOUNT ORDER BY 1"
        ).to_pandas()
    except Exception:
        return pd.DataFrame()


def resolve_account_keyword(keyword: str) -> dict:
    """Search account hierarchy deepest-first for a keyword match."""
    df = load_account_hierarchy()
    if df.empty:
        return {}
    kw_lower = keyword.lower().strip()
    for level_idx in range(3, -1, -1):   # L4 → L3 → L2 → L1
        col = _ACCOUNT_HIERARCHY_LEVELS[level_idx]
        if col not in df.columns:
            continue
        for val in df[col].dropna().unique():
            if val and kw_lower in str(val).lower():
                return {"level_idx": level_idx, "level_col": col, "matched_value": str(val)}
    return {}


_KEYWORD_HINTS = [
    "travel", "t&e", "software", "consulting", "salary", "bonus",
    "depreciation", "amortization", "facilities", "equipment", "rent",
    "training", "recruitment", "insurance", "utilities", "communications",
    "employee", "variable", "fixed", "opex", "compensation", "stock",
    "contractor", "marketing", "legal", "healthcare", "patent",
    "conference", "promotion", "logistics", "maintenance", "bad debt",
    "commissions", "fees", "allocation", "services", "subscriptions",
]


def detect_account_keywords(text: str) -> list[dict]:
    """Return list of hierarchy matches for known keywords found in the question."""
    matches = []
    text_lower = text.lower()
    for kw in _KEYWORD_HINTS:
        if kw in text_lower:
            result = resolve_account_keyword(kw)
            if result and not any(m["matched_value"] == result["matched_value"] for m in matches):
                matches.append(result)
    return matches


# ── VERSION AUTO-DETECTION ────────────────────────────────────────────────────
# FY starts October: P01=Oct, P02=Nov, P03=Dec, P04=Jan … P12=Sep
_MONTH_TO_PERIOD_NUM: dict[str, int] = {
    "oct":1,"nov":2,"dec":3,"jan":4,"feb":5,"mar":6,
    "apr":7,"may":8,"jun":9,"jul":10,"aug":11,"sep":12,
    "october":1,"november":2,"december":3,"january":4,"february":5,"march":6,
    "april":7,"june":9,"july":10,"august":11,"september":12,
}
_VER_ACTUAL   = {"actual","actuals","spent","realized","incurred","real"}
_VER_BUDGET   = {"budget","budgeted","overbudget","underbudget","budgetary","plan","planned"}
_VER_FORECAST = {"forecast","forecasted","fcst","projected","projection"}

_ALL_FORECAST_VERSIONS = [
    "FY26 FCST P01","FY26 FCST P02","FY26 FCST P02 Prelim",
    "FY26 FCST P03","FY26 FCST P03 Final","FY26 FCST P04",
    "FY26 FCST P05","FY26 FCST P05 Prelim","FY26 FCST P06",
    "FY26 FCST P06 Final","FY26 FCST P07","FY26 FCST P08 Prelim",
]


def detect_versions_from_question(question: str, sel_years: list[str]) -> list[str]:
    """
    Keyword → version list.  Returns [] if nothing detected
    (caller then applies default 'Actual' via enforce_filters).
    """
    q     = question.lower()
    words = set(re.findall(r"[a-z]+", q))
    versions: list[str] = []

    if words & _VER_ACTUAL:
        versions.append("Actual")
    if words & _VER_BUDGET:
        versions.append("Budget X")
    if words & _VER_FORECAST:
        fy_match = re.search(r"\bfy\s*(\d{2,4})\b", q)
        fy_str   = fy_match.group(1)[-2:] if fy_match \
                   else (sel_years[-1] if sel_years else default_year())[-2:]
        period_num = None
        p_match = re.search(r"\bp\s*0?(\d{1,2})\b", q)
        if p_match:
            period_num = int(p_match.group(1))
        else:
            nm = re.search(r"period\s+(\d{1,2})", q)
            if nm:
                period_num = int(nm.group(1))
        if period_num is None:
            for mname, pnum in _MONTH_TO_PERIOD_NUM.items():
                if re.search(r"\b" + mname + r"\b", q):
                    period_num = pnum
                    break
        if period_num is not None:
            versions.append(f"FY{fy_str} FCST P{period_num:02d}")
        else:
            versions.extend(v for v in _ALL_FORECAST_VERSIONS if v.startswith(f"FY{fy_str}"))

    return versions   # empty = no override; enforce_filters defaults to Actual


# ── QUESTION BUILDER (improved: hierarchy + version context) ──────────────────
def build_filtered_question(question: str, filters: dict) -> str:
    """
    Prepend mandatory context to the question for Cortex Analyst.
    Includes: currency, hierarchy keyword context, L1 dimension filters,
    period, and version (or default-to-Actual instruction).
    """
    parts: list[str] = []

    currency_map = {"EUR":"VAL_EUR","USD":"VAL_USD_INI","LC":"VAL_LC","Local Currency (LC)":"VAL_LC","DC":"VAL_EUR_NORM"}
    currency = filters.get("currency","EUR")
    val_col  = currency_map.get(currency,"VAL_EUR")
    parts.append(f"Use {val_col} as the value/amount column for all aggregations (currency: {currency}).")

    # Hierarchy keyword detection — inject explicit JOIN + filter + SELECT instructions
    hier_matches = detect_account_keywords(question)
    for m in hier_matches:
        level_name = m["level_col"].replace("_"," ").title()
        parts.append(
            f"IMPORTANT: The user is asking about '{m['matched_value']}' which is found at "
            f"{level_name} in the account hierarchy. "
            f"JOIN the fact table ACCOUNT column to "
            f"ACC_PRD.MASTERDATA.VW_JEDOX_MASTER_DATA_ACCOUNT.ACCOUNT_CODE "
            f"and filter WHERE {m['level_col']} = '{m['matched_value']}'. "
            f"Include ACCOUNT_LEVEL_1, ACCOUNT_LEVEL_2, ACCOUNT_LEVEL_3, ACCOUNT_LEVEL_4 in SELECT."
        )

    # L1 filters (from sidebar)
    acct_l1 = filters.get("account_l1",["OPEX"])
    if acct_l1:
        in_list = ", ".join(f"'{v}'" for v in acct_l1)
        parts.append(
            f"MANDATORY: Only ACCOUNT_LEVEL_1 IN ({in_list}). "
            f"JOIN fact.ACCOUNT = ACC_PRD.MASTERDATA.VW_JEDOX_MASTER_DATA_ACCOUNT.ACCOUNT_CODE "
            f"WHERE ACCOUNT_LEVEL_1 IN ({in_list})."
        )

    entity_l1 = filters.get("entity_l1",[])
    if entity_l1:
        in_list = ", ".join(f"'{v}'" for v in entity_l1)
        parts.append(
            f"Entity filter: JOIN fact.ENTITY = ACC_PRD.MASTERDATA.VW_JEDOX_MASTER_DATA_ENTITY.ENTITY_CODE "
            f"WHERE ENTITY_LEVEL_1 IN ({in_list})."
        )

    cc_l1 = filters.get("cost_center_l1",[])
    if cc_l1:
        in_list = ", ".join(f"'{v}'" for v in cc_l1)
        parts.append(
            f"Cost Center filter: JOIN fact.COST_CENTER = ACC_PRD.MASTERDATA.VW_JEDOX_MASTER_DATA_COST_CENTER.COST_CENTER_CODE "
            f"WHERE COST_CENTER_LEVEL_1 IN ({in_list})."
        )

    fa_l1 = filters.get("func_area_l1",[])
    if fa_l1:
        in_list = ", ".join(f"'{v}'" for v in fa_l1)
        parts.append(
            f"Functional Area filter: JOIN fact.FUNCTIONAL_AREA = ACC_PRD.MASTERDATA.VW_JEDOX_MASTER_DATA_FUNC_AREA.FUNC_AREA_CODE "
            f"WHERE FUNC_AREA_LEVEL_1 IN ({in_list})."
        )

    pc_l1 = filters.get("profit_center_l1",[])
    if pc_l1:
        in_list = ", ".join(f"'{v}'" for v in pc_l1)
        parts.append(
            f"Profit Center filter: JOIN fact.PROFIT_CENTER = ACC_PRD.MASTERDATA.VW_JEDOX_MASTER_DATA_PROFIT_CENTER.PROFIT_CENTER_CODE "
            f"WHERE PROFIT_CENTER_LEVEL_1 IN ({in_list})."
        )

    periods = filters.get("periods",[])
    if periods:
        preview = ", ".join(periods[:8])
        more    = f" (+{len(periods)-8} more)" if len(periods) > 8 else ""
        parts.append(f"TIME column filter (YYYY-MM format): TIME IN ({preview}{more})")

    versions = filters.get("versions",[])
    if versions:
        in_list = ", ".join(f"'{v}'" for v in versions)
        parts.append(f"VERSION filter: VERSION IN ({in_list})")
    else:
        parts.append("VERSION filter: Default to VERSION = 'Actual' unless user explicitly mentions budget or forecast.")

    if not parts:
        return question

    ctx = "MANDATORY CONTEXT - Apply ALL these conditions to the SQL query:\n" + \
          "\n".join(f"  * {p}" for p in parts)
    return f"{ctx}\n\nQuestion: {question}"


def filter_summary(filters: dict) -> str:
    parts: list[str] = []
    periods = filters.get("periods",[])
    if periods:
        fy_set = sorted({p[:4] for p in periods})
        parts.append(f"FY {' / '.join(fy_set)}")
    parts.append(filters.get("currency","EUR"))
    versions = filters.get("versions",[])
    if versions:
        parts.append(f"Ver: {', '.join(versions[:2])}" + (f" +{len(versions)-2}" if len(versions)>2 else ""))
    acct = filters.get("account_l1",[])
    if acct:
        parts.append(f"Acct: {', '.join(acct[:2])}")
    entity = filters.get("entity_l1",[])
    if entity:
        parts.append(f"Entity: {', '.join(entity[:2])}")
    return " · ".join(parts) if parts else "Ask a question — filters auto-applied"


# ── CORTEX ANALYST CALL (unchanged from Main — IN_SIS pattern) ───────────────
def call_analyst(filtered_question: str) -> dict:
    body = {
        "messages": [{"role":"user","content":[{"type":"text","text":filtered_question}]}],
        "semantic_view": SEMANTIC_VIEW,
    }
    if IN_SIS:
        resp = _snowflake.send_snow_api_request(
            "POST", ANALYST_URL_SUFFIX, {}, {}, body, {}, 45000
        )
        if resp.get("status") != 200:
            raise RuntimeError(
                f"Cortex Analyst {resp.get('status')}: {resp.get('content','(no detail)')}"
            )
        return json.loads(resp["content"])
    else:
        conn  = session.connection
        token = conn.rest.token
        host  = conn.host
        url   = f"https://{host}{ANALYST_URL_SUFFIX}"
        headers = {"Authorization": f'Snowflake Token="{token}"', "Content-Type":"application/json"}
        r = requests.post(url, json=body, headers=headers, timeout=60)
        if r.status_code != 200:
            raise RuntimeError(f"Cortex Analyst {r.status_code}: {r.text[:500]}")
        return r.json()


def parse_analyst_response(resp: dict) -> tuple[str | None, str]:
    sql, texts = None, []
    for block in resp.get("message",{}).get("content",[]):
        if block.get("type") == "sql":
            sql = block.get("statement","").strip()
        elif block.get("type") == "text":
            texts.append(block.get("text",""))
    return sql, " ".join(texts).strip()


# ── ENFORCE FILTERS (from task_v2 — builds CTE with proper dim JOINs) ────────
def enforce_filters(sql: str, filters: dict) -> str:
    """
    Replace fact table reference with a pre-filtered CTE that enforces
    L1 dimension filters and version. Compatible with Cortex-generated SQL.
    """
    if not sql:
        return sql

    acct_l1   = filters.get("account_l1",   ["OPEX"])
    entity_l1 = filters.get("entity_l1",    [])
    cc_l1     = filters.get("cost_center_l1",[])
    fa_l1     = filters.get("func_area_l1",  [])
    pc_l1     = filters.get("profit_center_l1",[])
    versions  = filters.get("versions",     [])
    periods   = filters.get("periods",      [])

    joins:  list[str] = []
    wheres: list[str] = []

    # Version — default Actual if nothing specified
    if versions:
        in_list = ", ".join(f"'{v}'" for v in versions)
        wheres.append(f"f.VERSION IN ({in_list})")
    else:
        wheres.append("f.VERSION = 'Actual'")

    # Period
    if periods:
        in_list = ", ".join(f"'{p}'" for p in periods)
        wheres.append(f"f.TIME IN ({in_list})")

    if acct_l1:
        joins.append("JOIN ACC_PRD.MASTERDATA.VW_JEDOX_MASTER_DATA_ACCOUNT __acct ON f.ACCOUNT = __acct.ACCOUNT_CODE")
        in_list = ", ".join(f"'{v}'" for v in acct_l1)
        wheres.append(f"__acct.ACCOUNT_LEVEL_1 IN ({in_list})")

    if entity_l1:
        joins.append("JOIN ACC_PRD.MASTERDATA.VW_JEDOX_MASTER_DATA_ENTITY __ent ON f.ENTITY = __ent.ENTITY_CODE")
        in_list = ", ".join(f"'{v}'" for v in entity_l1)
        wheres.append(f"__ent.ENTITY_LEVEL_1 IN ({in_list})")

    if cc_l1:
        joins.append("JOIN ACC_PRD.MASTERDATA.VW_JEDOX_MASTER_DATA_COST_CENTER __cc ON f.COST_CENTER = __cc.COST_CENTER_CODE")
        in_list = ", ".join(f"'{v}'" for v in cc_l1)
        wheres.append(f"__cc.COST_CENTER_LEVEL_1 IN ({in_list})")

    if fa_l1:
        joins.append("JOIN ACC_PRD.MASTERDATA.VW_JEDOX_MASTER_DATA_FUNC_AREA __fa ON f.FUNCTIONAL_AREA = __fa.FUNC_AREA_CODE")
        in_list = ", ".join(f"'{v}'" for v in fa_l1)
        wheres.append(f"__fa.FUNC_AREA_LEVEL_1 IN ({in_list})")

    if pc_l1:
        joins.append("JOIN ACC_PRD.MASTERDATA.VW_JEDOX_MASTER_DATA_PROFIT_CENTER __pc ON f.PROFIT_CENTER = __pc.PROFIT_CENTER_CODE")
        in_list = ", ".join(f"'{v}'" for v in pc_l1)
        wheres.append(f"__pc.PROFIT_CENTER_LEVEL_1 IN ({in_list})")

    if not wheres:
        return sql

    fact_pattern = re.compile(r"\bEDW_DEV\.WH\.VW_JEDOX_DATA_OPEX\b", re.I)
    if not fact_pattern.search(sql):
        return sql

    join_block  = "\n    ".join(joins)
    where_block = "\n      AND ".join(wheres)

    filtered_cte = (
        f"__opex_filtered AS (\n"
        f"    SELECT f.*\n"
        f"    FROM EDW_DEV.WH.VW_JEDOX_DATA_OPEX f\n"
        f"    {join_block}\n"
        f"    WHERE {where_block}\n"
        f")"
    )

    replaced = fact_pattern.sub("__opex_filtered", sql)

    if re.match(r"\s*WITH\b", replaced, re.I):
        replaced = re.sub(r"(?i)^\s*WITH\s+", "", replaced, count=1)
        return f"WITH {filtered_cte},\n{replaced}"
    return f"WITH {filtered_cte}\n{replaced}"


def run_query(sql: str) -> pd.DataFrame:
    return session.sql(sql).to_pandas()


# ── CHART DETECTION (from task_v2 — adds scatter / waterfall) ─────────────────
_TIME_RE = re.compile(r"period|month|year|date|time|quarter|cal_year", re.I)
_VAR_RE  = re.compile(r"variance|delta|deviation|change|growth|pct|percent|ratio", re.I)

def detect_chart(df: pd.DataFrame) -> str:
    if df.empty or len(df.columns) < 2:
        return "table"
    num_cols = df.select_dtypes(include="number").columns.tolist()
    str_cols = df.select_dtypes(exclude="number").columns.tolist()
    if not num_cols:
        return "table"
    if len(df) == 1:
        return "kpi"
    if not str_cols and len(num_cols) == 2:
        return "scatter"
    time_cols = [c for c in str_cols if _TIME_RE.search(c)]
    if time_cols and num_cols:
        return "line"
    if len(str_cols) == 1 and num_cols:
        return "bar" if len(df) <= 20 else "hbar"
    if len(str_cols) == 2 and len(num_cols) == 1:
        return "grouped_bar"
    var_cols = [c for c in num_cols if _VAR_RE.search(c)]
    if var_cols and str_cols:
        return "waterfall"
    return "table"


def build_chart(df: pd.DataFrame, chart_type: str, question: str = "") -> bool:
    num_cols  = df.select_dtypes(include="number").columns.tolist()
    str_cols  = df.select_dtypes(exclude="number").columns.tolist()
    time_cols = [c for c in str_cols if _TIME_RE.search(c)]
    try:
        if chart_type == "line" and time_cols and num_cols:
            chart_df = df.sort_values(time_cols[0]).set_index(time_cols[0])[num_cols]
            st.line_chart(chart_df)
            return True
        elif chart_type in ("bar","hbar") and str_cols and num_cols:
            df_s     = df.sort_values(num_cols[0], ascending=False).head(25)
            chart_df = df_s.set_index(str_cols[0])[num_cols]
            st.bar_chart(chart_df)
            return True
        elif chart_type == "grouped_bar" and len(str_cols) >= 2 and num_cols:
            pivot_df = df.pivot_table(
                index=str_cols[0], columns=str_cols[1],
                values=num_cols[0], aggfunc="sum"
            ).fillna(0)
            st.bar_chart(pivot_df)
            return True
        elif chart_type == "waterfall" and str_cols and num_cols:
            var_cols = [c for c in num_cols if _VAR_RE.search(c)]
            y_col    = var_cols[0] if var_cols else num_cols[0]
            df_s     = df.sort_values(y_col, ascending=False).head(25)
            st.bar_chart(df_s.set_index(str_cols[0])[[y_col]])
            return True
        elif chart_type == "scatter" and len(num_cols) >= 2:
            st.scatter_chart(df, x=num_cols[0], y=num_cols[1])
            return True
        return False
    except Exception:
        return False


def fmt_num(v: float) -> str:
    if abs(v) >= 1_000_000_000: return f"{v/1_000_000_000:.2f}B"
    if abs(v) >= 1_000_000:     return f"{v/1_000_000:.2f}M"
    if abs(v) >= 1_000:         return f"{v/1_000:.1f}K"
    return f"{v:,.2f}"

def show_kpi_cards(df: pd.DataFrame):
    num_cols = df.select_dtypes(include="number").columns.tolist()
    cards = "".join(
        f'<div class="kpi-card">'
        f'<div class="kpi-label">{c.replace("_"," ").title()}</div>'
        f'<div class="kpi-value">{fmt_num(df[c].iloc[0])}</div>'
        f'</div>'
        for c in num_cols[:6]
    )
    st.markdown(f'<div class="kpi-row">{cards}</div>', unsafe_allow_html=True)


