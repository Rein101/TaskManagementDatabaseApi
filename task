# FILTER SUMMARY (shown as context chips, not a sidebar wall)
# ─────────────────────────────────────────────────────────────────────────────
def filter_summary_html(years, quarters, months, currency,
                        entity_l1, versions, hier_matches) -> str:
    chips = []
    if years:
        chips.append(f"📅 {', '.join(years)}")
    if quarters:
        chips.append(f"Q {', '.join(quarters)}")
