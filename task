# ─── FISCAL PERIOD HELPERS ────────────────────────────────────────────────────
def fiscal_years() -> list[str]:
    y = date.today().year
    return [str(y - 2), str(y - 1), str(y)]

def fiscal_quarters() -> list[str]:
    return ["Q1", "Q2", "Q3", "Q4"]

def fiscal_months() -> list[str]:
    return ["Jan","Feb","Mar","Apr","May","Jun",
            "Jul","Aug","Sep","Oct","Nov","Dec"]

def default_year() -> str:
    return str(date.today().year)

def default_quarter() -> str:
    # FY starts October: (month-10)%12 shifts Oct→0, Nov→1 … Sep→11
    shifted = (date.today().month - 10) % 12
    return f"Q{shifted // 3 + 1}"

def default_month() -> str:
    return date.today().strftime("%b")

def available_months_for_quarters(selected_quarters: list[str]) -> list[str]:
    """Return month abbreviations that belong to the selected quarters."""
    if not selected_quarters:
        return fiscal_months()
    months = []
    for q in ["Q1", "Q2", "Q3", "Q4"]:
        if q in selected_quarters:
            months.extend(_QUARTER_MONTH_ABBRS[q])
    return months

def compute_periods(
    sel_years: list[str],
    sel_quarters: list[str],
    sel_months: list[str],
) -> list[str]:
    """
    Convert UI selections → sorted YYYYMM strings.
    sel_months is an optional within-quarter filter; empty = all months.
    """
    if not sel_years:
        return []
    quarters  = sel_quarters if sel_quarters else ["Q1", "Q2", "Q3", "Q4"]
    month_nums = {_MONTH_TO_NUM[m] for m in sel_months} if sel_months else None

    periods: set[str] = set()
    for fy_str in sel_years:
        fy = int(fy_str)
        for q in quarters:
            yr_offset, q_months = _QUARTER_CALENDAR[q]
            cal_year = fy + yr_offset
            for m in q_months:
                if month_nums is None or m in month_nums:
                    periods.add(f"{cal_year}{m:02d}")
    return sorted(periods)


# ─── DIMENSION FILTER LOADER ──────────────────────────────────────────────────
@st.cache_data(ttl=600)
def get_filter_values(dimension: str) -> list[str]:
    """Load distinct code values from a dimension master view."""
    if dimension not in _DIM_TABLES:
        return []
    table, col = _DIM_TABLES[dimension]
    try:
        df = session.sql(f"""
            SELECT DISTINCT {col} AS VAL
            FROM {table}
            WHERE {col} IS NOT NULL
            ORDER BY 1
        """).to_pandas()
        return df["VAL"].tolist()
    except Exception:
        return []


# ─── FILTER → QUESTION BUILDER ────────────────────────────────────────────────
def build_filtered_question(question: str, filters: dict) -> str:
    """
    Prefix the user question with a plain-English filter block so Cortex
    Analyst restricts its generated SQL to those dimensions automatically.
    """
    parts: list[str] = []

    periods = filters.get("periods", [])
    if periods:
        preview = ", ".join(periods[:8])
        more    = f" (+{len(periods)-8} more)" if len(periods) > 8 else ""
        parts.append(f"Fiscal periods (YYYYMM format): {preview}{more}")

    dim_labels = [
        ("versions",         "Version / Scenario"),
        ("entities",         "Entity"),
        ("cost_centers",     "Cost Center"),
        ("functional_areas", "Functional Area"),
        ("accounts",         "GL Account"),
        ("profit_centers",   "Profit Center"),
    ]
    for key, label in dim_labels:
        vals = filters.get(key, [])
        if vals:
            parts.append(f"{label}: {', '.join(vals)}")

    if not parts:
        return question

    ctx = "Active filters (apply these to the analysis):\n" + "\n".join(
        f"  • {p}" for p in parts
    )
    return f"{ctx}\n\nQuestion: {question}"


def filter_summary(filters: dict) -> str:
    """One-line badge text summarising active filters."""
    parts: list[str] = []
    periods = filters.get("periods", [])
    if periods:
        # Show fiscal years + quarters in a compact form
        fy_set  = sorted({p[:4] for p in periods})
        parts.append(f"FY {' / '.join(fy_set)}")
    for key, label in [
        ("versions",""),("entities","Entity"),("cost_centers","CC"),
        ("functional_areas","FA"),("accounts","Acct"),("profit_centers","PC"),
    ]:
        vals = filters.get(key, [])
        if vals:
            short = ", ".join(vals[:2]) + (f" +{len(vals)-2}" if len(vals) > 2 else "")
            prefix = f"{label}: " if label else ""
            parts.append(f"{prefix}{short}")
    return " · ".join(parts) if parts else "No filters — showing all data"


# ─── CORTEX ANALYST ──────────────────────────────────────────────────────────
def call_analyst(filtered_question: str) -> dict | None:
    body = {
        "messages": [{
            "role": "user",
            "content": [{"type": "text", "text": filtered_question}],
        }],
        "semantic_model_file": SEMANTIC_MODEL_STAGE,
    }
    if _IN_SIS:
        resp = _snowflake.send_snow_api_request(
            "POST", ANALYST_ENDPOINT, {}, {}, body, {}, 45000
        )
        if resp.get("status") != 200:
            st.error(f"Cortex Analyst error {resp.get('status')}: {resp.get('content','')}")
            return None
        return json.loads(resp["content"])
    st.error("Cortex Analyst requires the SiS environment. Deploy to Snowflake Streamlit.")
    return None


def parse_analyst_response(resp: dict) -> tuple[str | None, str]:
    sql, texts = None, []
    for block in resp.get("message", {}).get("content", []):
        if block.get("type") == "sql":
            sql = block.get("statement", "").strip()
        elif block.get("type") == "text":
            texts.append(block.get("text", ""))
    return sql, " ".join(texts).strip()


# ─── SQL RUNNER ───────────────────────────────────────────────────────────────
def run_query(sql: str) -> pd.DataFrame:
    if _IN_SIS:
        return session.sql(sql).to_pandas()
    cur = session.cursor()
    cur.execute(sql)
    cols = [d[0] for d in cur.description]
    return pd.DataFrame(cur.fetchall(), columns=cols)


# ─── CHART DETECTION ─────────────────────────────────────────────────────────
_TIME_RE = re.compile(r"period|month|year|date|time|quarter|cal_year", re.I)
_VAR_RE  = re.compile(r"variance|delta|deviation|change|growth|pct|percent|ratio", re.I)

def detect_chart(df: pd.DataFrame) -> str:
    if df.empty or len(df.columns) < 2:
        return "table"
    num_cols = df.select_dtypes(include="number").columns.tolist()
    str_cols = df.select_dtypes(exclude="number").columns.tolist()
    if not num_cols:
        return "table"
    if len(df) == 1:
        return "kpi"
    if not str_cols and len(num_cols) == 2:
        return "scatter"
    time_cols = [c for c in str_cols if _TIME_RE.search(c)]
    if time_cols and num_cols:
        return "line"
    if len(str_cols) == 1 and num_cols:
        return "bar" if len(df) <= 20 else "hbar"
    if len(str_cols) == 2 and len(num_cols) == 1:
        return "grouped_bar"
    var_cols = [c for c in num_cols if _VAR_RE.search(c)]
    if var_cols and str_cols:
        return "waterfall"
    return "table"


# ─── CHART BUILDER ───────────────────────────────────────────────────────────
COLORS = ["#29B5E8","#0073B6","#00C4B3","#F97316","#8B5CF6",
          "#10B981","#F59E0B","#EF4444","#6366F1","#14B8A6"]
_LAYOUT = dict(
    plot_bgcolor="white", paper_bgcolor="white",
    font=dict(family="Inter, Helvetica Neue, sans-serif", size=12),
    height=420, margin=dict(l=40,r=20,t=50,b=50),
    legend=dict(orientation="h", yanchor="bottom", y=1.02, xanchor="right", x=1),
    title_font_size=14,
)

def build_chart(df: pd.DataFrame, chart_type: str, question: str) -> go.Figure | None:
    num_cols  = df.select_dtypes(include="number").columns.tolist()
    str_cols  = df.select_dtypes(exclude="number").columns.tolist()
    time_cols = [c for c in str_cols if _TIME_RE.search(c)]
    title     = (question[:72] + "…") if len(question) > 72 else question
    try:
        if chart_type == "line" and time_cols and num_cols:
            fig = px.line(df.sort_values(time_cols[0]), x=time_cols[0], y=num_cols,
                          title=title, color_discrete_sequence=COLORS, markers=True)
            fig.update_traces(line_width=2.5)

        elif chart_type == "bar" and str_cols and num_cols:
            df_s = df.sort_values(num_cols[0], ascending=False).head(25)
            fig = px.bar(df_s, x=str_cols[0], y=num_cols, title=title,
                         color_discrete_sequence=COLORS, barmode="group")

        elif chart_type == "hbar" and str_cols and num_cols:
            df_s = df.nlargest(25, num_cols[0])
            fig = px.bar(df_s, x=num_cols[0], y=str_cols[0], orientation="h",
                         title=title, color_discrete_sequence=[COLORS[0]])
            fig.update_layout(yaxis={"categoryorder": "total ascending"})

        elif chart_type == "grouped_bar" and len(str_cols) >= 2 and num_cols:
            fig = px.bar(df, x=str_cols[0], y=num_cols[0], color=str_cols[1],
                         title=title, barmode="group", color_discrete_sequence=COLORS)

        elif chart_type == "waterfall" and str_cols and num_cols:
            var_cols = [c for c in num_cols if _VAR_RE.search(c)]
            y_col = var_cols[0] if var_cols else num_cols[0]
            df_s  = df.sort_values(y_col)
            fig   = go.Figure(go.Bar(
                x=df_s[str_cols[0]], y=df_s[y_col],
                marker_color=["#EF4444" if v > 0 else "#10B981" for v in df_s[y_col]],
                text=[f"{v:+,.0f}" for v in df_s[y_col]], textposition="outside",
            ))
            fig.update_layout(title=title)

        elif chart_type == "scatter" and len(num_cols) >= 2:
            fig = px.scatter(df, x=num_cols[0], y=num_cols[1],
                             hover_data=str_cols[:2] if str_cols else None,
                             title=title, color_discrete_sequence=[COLORS[0]])
        else:
            return None

        fig.update_layout(**_LAYOUT)
        fig.update_xaxes(showgrid=False, tickangle=(-30 if chart_type != "hbar" else 0))
        fig.update_yaxes(showgrid=True, gridcolor="#F3F4F6",
                         zeroline=True, zerolinecolor="#E5E7EB")
        return fig
    except Exception:
        return None


# ─── KPI CARDS ───────────────────────────────────────────────────────────────
def fmt_num(v: float) -> str:
    if abs(v) >= 1_000_000_000: return f"{v/1_000_000_000:.2f}B"
    if abs(v) >= 1_000_000:     return f"{v/1_000_000:.2f}M"
    if abs(v) >= 1_000:         return f"{v/1_000:.1f}K"
    return f"{v:,.2f}"

def show_kpi_cards(df: pd.DataFrame):
    num_cols = df.select_dtypes(include="number").columns.tolist()
    cards = "".join(
        f'<div class="kpi-card">'
        f'<div class="kpi-label">{c.replace("_"," ").title()}</div>'
        f'<div class="kpi-value">{fmt_num(df[c].iloc[0])}</div>'
        f'</div>'
        for c in num_cols[:6]
    )
    st.markdown(f'<div class="kpi-row">{cards}</div>', unsafe_allow_html=True)


# ─── NARRATIVE ────────────────────────────────────────────────────────────────
def generate_narrative(question: str, df: pd.DataFrame) -> str:
    if df.empty:
        return ""
    top    = df.head(8).to_string(index=False, max_colwidth=30)
    prompt = (
        f'You are a senior financial analyst writing an executive insight.\n\n'
        f'Question: "{question}"\n'
        f'Result rows: {len(df)} | Columns: {", ".join(df.columns)}\n'
        f'Sample data:\n{top}\n\n'
        f'Write exactly 2-3 sentences. Be specific with numbers. '
        f'Highlight the single most important finding. '
        f'No preamble. Business language.'
    )
    try:
        return Complete(NARRATIVE_MODEL, prompt) if _IN_SIS else "(Narrative: SiS only)"
    except Exception as e:
        return f"(Narrative error: {e})"


