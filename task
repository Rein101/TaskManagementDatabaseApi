# ─────────────────────────────────────────────────────────────────────────────
def fiscal_years() -> list[str]:
    y = date.today().year
    return [str(y-2), str(y-1), str(y)]
 
def default_year() -> str:
    return str(date.today().year)
 
def default_quarter() -> str:
    shifted = (date.today().month - 10) % 12
    return f"Q{shifted // 3 + 1}"
 
def compute_periods(sel_years, sel_quarters, sel_months) -> list[str]:
    if not sel_years:
        return []
    quarters = sel_quarters if sel_quarters else ["Q1","Q2","Q3","Q4"]
    month_nums = {_MONTH_TO_NUM[m] for m in sel_months} if sel_months else None
    periods: set[str] = set()
    for fy_str in sel_years:
        fy = int(fy_str)
        for q in quarters:
            yr_offset, q_months = _QUARTER_CALENDAR[q]
            cal_year = fy + yr_offset
            for m in q_months:
                if month_nums is None or m in month_nums:
                    periods.add(f"{cal_year}-{m:02d}")
    return sorted(periods)
 
 
# ─────────────────────────────────────────────────────────────────────────────
# VERSION AUTO-DETECTION
# ─────────────────────────────────────────────────────────────────────────────
def detect_versions(question: str, sel_years: list[str]) -> list[str]:
    """
    Parse natural language to resolve version strings.
    Returns a list of version values to filter on.
    'actual/cost/spend'            → ['Actual']
    'budget/overbudget/budgeted'   → ['Budget X']
    'forecast/fcst + period/month' → ['FY26 FCST P03']  (specific)
    'forecast' alone               → ['FY26 FCST%']      (all forecasts for year)
    Multiple keywords → multiple versions returned.
    """
    q     = question.lower()
    words = set(re.findall(r"[a-z]+", q))
    versions: list[str] = []
 
    # ── Actual ────────────────────────────────────────────────────────────────
    if words & _VER_ACTUAL:
        versions.append("Actual")
 
    # ── Budget ────────────────────────────────────────────────────────────────
    if words & _VER_BUDGET:
        versions.append("Budget X")
 
    # ── Forecast ─────────────────────────────────────────────────────────────
    if words & _VER_FORECAST:
        # Detect fiscal year: prefer explicit mention, else sidebar selection
        fy_match = re.search(r"\bfy\s*(\d{2,4})\b", q)
        if fy_match:
            raw = fy_match.group(1)
            fy_str = raw[-2:]           # last 2 digits, e.g. "26"
        else:
            fy_str = (sel_years[-1] if sel_years else default_year())[-2:]
 
        # Detect period number: "P03", "period 3", "period three"
        period_num = None
        p_match = re.search(r"\bp\s*0?(\d{1,2})\b", q)
        if p_match:
            period_num = int(p_match.group(1))
        else:
            period_word = re.search(r"period\s+(\d{1,2})", q)
            if period_word:
                period_num = int(period_word.group(1))
 
        # Detect month name
        if period_num is None:
            for month_name, p_code in _MONTH_TO_PERIOD.items():
                if re.search(r"\b" + month_name + r"\b", q):
                    period_num = int(p_code[1:])    # P03 → 3
                    break
 
        if period_num is not None:
            versions.append(f"FY{fy_str} FCST P{period_num:02d}")
        else:
            # No specific period → all forecasts for the year
            versions.append(f"FY{fy_str} FCST%")   # handled as LIKE in SQL
 
    # ── Default: if nothing detected and question seems data-oriented ─────────
    if not versions:
        versions = ["Actual"]   # safest default
 
    return versions
 
 
def versions_to_sql_clause(versions: list[str]) -> str:
    """Convert version list to a SQL WHERE clause fragment."""
    exact, like = [], []
    for v in versions:
        if v.endswith("%"):
            like.append(f'"VERSION" LIKE \'{v}\'')
        else:
            exact.append(f"'{v}'")
    parts = []
    if exact:
        parts.append(f'"VERSION" IN ({", ".join(exact)})')
    parts.extend(like)
    return "(" + " OR ".join(parts) + ")" if parts else "1=1"
 
 
# ─────────────────────────────────────────────────────────────────────────────
# HIERARCHY AUTO-RESOLUTION
# ─────────────────────────────────────────────────────────────────────────────
@st.cache_data(ttl=600)
def search_hierarchy(dim: str, keyword: str) -> dict | None:
    """
    Search a dimension's hierarchy levels deepest-first for keyword.
    Returns {dim, level_col, level_num, matched_value} or None.
    Cached so repeated lookups for common terms (travel, R&D) are free.
    """
    tbl, _key, levels = _DIM[dim]
    # Reverse: try deepest level first (L4 → L3 → L2 → L1)
    for col in reversed(levels):
        if "CODE_AND_DESC" in col:
            continue     # skip code column for hierarchy matching
        try:
            df = session.sql(f"""
                SELECT DISTINCT {col} AS VAL
                FROM {tbl}
                WHERE LOWER({col}) LIKE '%{keyword.lower()}%'
                  AND {col} IS NOT NULL
                LIMIT 1
            """).to_pandas()
            if not df.empty:
                level_num = int(re.search(r"_(\d)$", col).group(1)) if re.search(r"_(\d)$", col) else 1
                return {
                    "dim":       dim,
                    "level_col": col,
                    "level_num": level_num,
                    "value":     df["VAL"].iloc[0],
                }
        except Exception:
            continue
    return None
 
 
def resolve_hierarchies(question: str) -> list[dict]:
    """
    Extract keywords from question, search all dimensions for matches.
    Returns list of hierarchy matches sorted by dimension.
    Skips generic stop-words to avoid false positives.
    """
    STOP_WORDS = {
        "the","and","for","are","what","show","me","by","in","of","to",
        "with","top","all","this","that","year","quarter","month","cost",
        "total","where","which","have","over","more","than","less","rate",
        "actual","budget","forecast","compare","vs","how","much","is",
        "does","their","has","per","current","prior","previous","last",
    }
    raw_words = re.findall(r"[a-zA-Z&]+", question)
    keywords  = [
        w.lower() for w in raw_words
        if len(w) > 2 and w.lower() not in STOP_WORDS
    ]
    # Also try bigrams for "travel entertainment", "functional area" etc.
    bigrams = [
        f"{raw_words[i].lower()} {raw_words[i+1].lower()}"
        for i in range(len(raw_words)-1)
        if raw_words[i].lower() not in STOP_WORDS
    ]
 
    found: dict[str, dict] = {}   # dim → best match (deepest level wins)
    for kw in keywords + bigrams:
        for dim in _DIM:
            if dim in found:
                continue    # already have a match for this dimension
            match = search_hierarchy(dim, kw)
            if match:
                found[dim] = match
 
    return list(found.values())
 
 
def hierarchies_to_context(matches: list[dict]) -> str:
    """
    Convert hierarchy matches to a natural language filter string
    appended to the Cortex Analyst question.
    """
    if not matches:
        return ""
    parts = []
    for m in matches:
        dim_label = m["dim"].replace("_"," ").title()
        parts.append(
            f"{dim_label} filtered to '{m['value']}' (at {m['level_col']})"
        )
    return " Additionally filter: " + "; ".join(parts) + "."
 
 
# ─────────────────────────────────────────────────────────────────────────────
# PIVOT-STYLE OUTPUT ENRICHMENT
# ─────────────────────────────────────────────────────────────────────────────
@st.cache_data(ttl=600)
def get_hierarchy_lookup(dim: str) -> pd.DataFrame:
    """Load the full hierarchy for a dimension as a lookup dataframe."""
    tbl, key, levels = _DIM[dim]
    cols = ", ".join([key] + levels)
    try:
        return session.sql(f"SELECT DISTINCT {cols} FROM {tbl}").to_pandas()
    except Exception:
        return pd.DataFrame()
 
 
def enrich_with_hierarchy(df: pd.DataFrame, matches: list[dict]) -> pd.DataFrame:
    """
    Left-join hierarchy lookup tables onto the result dataframe so that
    every row has full Level1→Level2→Level3→Level4→Code context.
    Only joins dimensions that were resolved and whose key column appears in df.
    """
    result = df.copy()
    for m in matches:
        dim = m["dim"]
        tbl, key_col, levels = _DIM[dim]
        # Check if the key column (or a close variant) exists in result
        matching_cols = [c for c in result.columns if key_col.lower() in c.lower()]
        if not matching_cols:
            continue
        df_key_col = matching_cols[0]
        lookup = get_hierarchy_lookup(dim)
        if lookup.empty:
            continue
        # Rename key col in lookup to match result column
        lookup = lookup.rename(columns={key_col: df_key_col})
        # Only add levels not already in result
        new_levels = [c for c in levels if c not in result.columns]
        if not new_levels:
            continue
        merge_cols = [df_key_col] + new_levels
        result = result.merge(
            lookup[[df_key_col] + new_levels],
            on=df_key_col, how="left"
        )
        # Reorder: hierarchy cols first, then numeric cols
        hier_cols = [c for c in result.columns if any(
            lv in c for lv in ["LEVEL_","CODE_AND_DESC"]
        )]
        other_cols = [c for c in result.columns if c not in hier_cols]
        result = result[hier_cols + other_cols]
    return result
 
 
# ─────────────────────────────────────────────────────────────────────────────
# CORTEX ANALYST CALL  (token fix, grounded SQL only)
# ─────────────────────────────────────────────────────────────────────────────
def call_analyst(question: str) -> dict:
    try:
        token = session.get_session_token()
    except Exception as e:
        return {"error": f"Token error: {e}. Ensure the app runs inside Streamlit in Snowflake."}
 
    try:
        account = session.get_current_account().strip('"').lower().replace("_","-")
        host    = f"{account}.snowflakecomputing.com"
    except Exception as e:
        return {"error": f"Cannot derive host: {e}"}
 
    try:
        resp = requests.post(
            f"https://{host}{ANALYST_URL_SUFFIX}",
            json={
                "messages": [{"role":"user",
                              "content":[{"type":"text","text":question}]}],
                "semantic_view": SEMANTIC_VIEW,
            },
            headers={
                "Authorization": f'Snowflake Token="{token}"',
                "Content-Type": "application/json",
            },
            timeout=120,
        )
    except Exception as e:
        return {"error": f"Network error: {e}"}
 
    if resp.status_code >= 400:
        return {"error": f"API {resp.status_code}: {resp.text[:300]}"}
 
    return resp.json()
 
 
def parse_analyst_response(resp: dict) -> tuple[str | None, str]:
    if "error" in resp:
        return None, resp["error"]
    sql, text, suggestions = None, "", []
    for block in resp.get("message", {}).get("content", []):
        t = block.get("type")
        if t == "sql":
            sql = block.get("statement","")
        elif t == "text":
            text = block.get("text","")
        elif t == "suggestions":
            suggestions = block.get("suggestions",[])
    if not sql:
        msg = text or ("Try: " + "; ".join(suggestions) if suggestions
                       else "No SQL generated.")
        return None, msg
    return sql, text
 
 
def run_query(sql: str) -> pd.DataFrame:
    try:
        return session.sql(sql).to_pandas()
    except Exception as e:
        st.error(f"SQL error: {e}")
        return pd.DataFrame()
 
 
# ─────────────────────────────────────────────────────────────────────────────
# CHART DETECTION  (pure Python — no LLM)
# ─────────────────────────────────────────────────────────────────────────────
def detect_chart(df: pd.DataFrame, question: str) -> str:
    if df.empty or len(df) < 2:
        return "table"
    q     = question.lower()
    cols  = list(df.columns)
    n_num = sum(1 for c in cols if pd.api.types.is_numeric_dtype(df[c]))
    date_cols = [c for c in cols if any(k in c.lower()
                 for k in ["time","period","month","quarter","year","date"])]
    if not n_num:
        return "table"
    if date_cols or any(k in q for k in ["trend","monthly","over time","ytd","period"]):
        return "line"
    if any(k in q for k in ["compare","vs ","versus","breakdown","split"]):
        return "bar_grouped"
    return "bar"
 
 
def build_chart(df: pd.DataFrame, chart_type: str, question: str = ""):
    try:
        import plotly.express as px
        import plotly.graph_objects as go
 
        cols     = list(df.columns)
        num_cols = [c for c in cols if pd.api.types.is_numeric_dtype(df[c])]
        str_cols = [c for c in cols if df[c].dtype == object]
        date_c   = next((c for c in cols if any(k in c.lower()
                         for k in ["time","period","month","quarter","date"])), None)
        x        = date_c or (str_cols[0] if str_cols else cols[0])
        y_cols   = [c for c in num_cols if c != x][:3]  # max 3 series
 
        if not y_cols:
            return
 
        COLORS = ["#0073B6","#29B5E8","#34D399","#FBBF24","#F87171"]
        kw     = dict(template="plotly_white", color_discrete_sequence=COLORS)
 
        if chart_type == "line":
            fig = px.line(df, x=x, y=y_cols, markers=True, **kw)
        elif chart_type == "bar_grouped" and len(y_cols) > 1:
            fig = px.bar(df, x=x, y=y_cols, barmode="group", **kw)
        else:
            fig = px.bar(df, x=x, y=y_cols[0],
                         color=x if len(df) <= 20 else None, **kw)
 
        fig.update_layout(
            margin=dict(t=24,b=16,l=8,r=8),
            xaxis=dict(gridcolor="#F1F5F9"),
            yaxis=dict(gridcolor="#F1F5F9", tickprefix="$", tickformat=",.0f"),
            legend=dict(bgcolor="rgba(0,0,0,0)"),
            showlegend=(len(y_cols) > 1),
        )
        fig.update_traces(marker_line_width=0)
        st.plotly_chart(fig, use_container_width=True)
    except Exception as e:
        st.caption(f"Chart unavailable: {e}")
 
 
# ─────────────────────────────────────────────────────────────────────────────
# NARRATIVE  (Python computes facts → LLM writes sentence)
# ─────────────────────────────────────────────────────────────────────────────
def generate_narrative(question: str, df: pd.DataFrame) -> str:
    if df.empty:
        return ""
    num_cols = [c for c in df.columns if pd.api.types.is_numeric_dtype(df[c])]
    str_cols = [c for c in df.columns if df[c].dtype == object]
    if not num_cols:
        return ""
 
    # Python derives all numbers — LLM never sees raw data
    usd_col   = next((c for c in num_cols if any(k in c.lower()
                      for k in ["usd","actual","amount","val"])), num_cols[0])
    group_col = str_cols[0] if str_cols else None
 
    try:
        sdf       = df.sort_values(usd_col, ascending=False)
        top_name  = sdf.iloc[0][group_col] if group_col else "N/A"
        top_val   = float(sdf.iloc[0][usd_col])
        total     = float(df[usd_col].sum())
        share     = round(top_val / total * 100, 1) if total else 0
        n         = len(df)
 
        prompt = (
            f"Write ONE professional sentence for a financial report. "
            f"Use ONLY these pre-computed facts — do not change any number:\n"
            f"- Highest: {top_name}  ${top_val:,.0f}  ({share}% of total)\n"
            f"- Total across {n} rows: ${total:,.0f}\n"
            f"- User asked: {question}\n"
            f"Plain text only, no markdown."
        )
        result = session.sql(
            "SELECT SNOWFLAKE.CORTEX.COMPLETE(?, ?)",
            params=[LLM_MODEL, prompt]
        ).collect()[0][0]
        return result.strip()
    except Exception:
        return ""
 
 
