                unsafe_allow_html=True)

    if turn.get("error"):
        st.error(turn["error"])
    else:
        if turn.get("agent_text"):
            st.markdown(f'<div class="bubble-agent">🤖 {turn["agent_text"]}</div>',
                        unsafe_allow_html=True)

        if st.session_state["show_sql"] and turn.get("sql"):
            with st.expander("🔍 Generated SQL", expanded=False):
                st.code(turn["sql"], language="sql")

        df = turn.get("df")
        if df is not None and not df.empty:
            ctype = turn.get("chart_type", "table")

            if st.session_state["show_chart"]:
                if ctype == "kpi":
                    show_kpi_cards(df)
                elif ctype != "table":
                    fig = build_chart(df, ctype, turn["question"])
                    if fig:
                        st.plotly_chart(fig, use_container_width=True)

            with st.expander(f"📋 Data — {len(df):,} rows", expanded=(ctype == "table")):
                st.dataframe(df, use_container_width=True, hide_index=True)
                st.download_button(
                    "⬇ Download CSV",
                    df.to_csv(index=False).encode("utf-8"),
                    "opex_export.csv", "text/csv",
                    key=f"dl_{id(turn)}",
                )

            if st.session_state["show_narr"] and turn.get("narrative"):
                st.markdown(
                    f'<div class="narrative-box">💡 {turn["narrative"]}</div>',
                    unsafe_allow_html=True,
                )

        elif df is not None and df.empty:
            st.info("The query returned no rows for the active filters.")

    st.markdown('<hr class="turn-divider">', unsafe_allow_html=True)


# ─── INPUT ────────────────────────────────────────────────────────────────────
col_q, col_btn = st.columns([6, 1])
with col_q:
    user_q = st.text_input(
        "question",
        value=st.session_state.get("pending", ""),
        placeholder="e.g. Which cost centers are over budget by more than 15%?",
        label_visibility="collapsed",
        key="input_box",
    )
with col_btn:
    go = st.button("Analyze →", type="primary", use_container_width=True)

if st.session_state.get("pending"):
    st.session_state["pending"] = ""


# ─── PROCESS ──────────────────────────────────────────────────────────────────
if go and user_q.strip():
    question = user_q.strip()
    turn: dict = {"question": question}

    with st.spinner("Analyzing with active filters…"):
        filtered_q = build_filtered_question(question, active_filters)
        try:
            resp = call_analyst(filtered_q)
            if resp is None:
                turn["error"] = "No response from Cortex Analyst."
            else:
                sql, agent_text = parse_analyst_response(resp)
                turn["agent_text"] = agent_text
                turn["sql"]        = sql

                if sql:
                    df = run_query(sql)
                    turn["df"]         = df
                    turn["chart_type"] = detect_chart(df)
                    if st.session_state["show_narr"] and not df.empty:
                        turn["narrative"] = generate_narrative(question, df)
                else:
                    turn["df"]         = pd.DataFrame()
                    turn["chart_type"] = "table"

        except Exception as exc:
            turn["error"] = f"Unexpected error: {exc}"

    st.session_state["history"].append(turn)
    st.rerun()
