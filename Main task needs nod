    versions = filters.get("versions", [])
    if versions:
        parts.append(", ".join(versions[:2]) + (f" +{len(versions)-2}" if len(versions) > 2 else ""))
    dim_short = {"account": "Acct", "cost_center": "CC", "entity": "Entity",
                 "functional_area": "FA", "profit_center": "PC"}
    hierarchy = filters.get("hierarchy", {})
    for dim, selections in hierarchy.items():
        if not selections:
            continue
        deepest = max(selections.keys())
        vals = selections[deepest]
        short = ", ".join(vals[:2]) + (f" +{len(vals)-2}" if len(vals) > 2 else "")
        spec = _DIM_HIERARCHY[dim]
        level_label = spec["level_labels"][deepest]
        parts.append(f"{dim_short.get(dim, dim)} {level_label}: {short}")
    return " | ".join(parts) if parts else "No filters - showing all data"


def call_analyst(filtered_question: str) -> dict:
    body = {
        "messages": [{
            "role": "user",
            "content": [{"type": "text", "text": filtered_question}],
        }],
        "semantic_view": SEMANTIC_VIEW,
    }
    if IN_SIS:
        resp = _snowflake.send_snow_api_request(
            "POST", ANALYST_URL_SUFFIX, {}, {}, body, {}, 45000
        )
        if resp.get("status") != 200:
            raise RuntimeError(
                f"Cortex Analyst {resp.get('status')}: {resp.get('content', '(no detail)')}"
            )
        return json.loads(resp["content"])
    else:
        conn = session.connection
        token = conn.rest.token
        host = conn.host
        url = f"https://{host}{ANALYST_URL_SUFFIX}"
        headers = {
            "Authorization": f'Snowflake Token="{token}"',
            "Content-Type": "application/json",
        }
        r = requests.post(url, json=body, headers=headers, timeout=60)
        if r.status_code != 200:
            raise RuntimeError(f"Cortex Analyst {r.status_code}: {r.text[:500]}")
        return r.json()


def parse_analyst_response(resp: dict) -> tuple[str | None, str]:
    sql, texts = None, []
    for block in resp.get("message", {}).get("content", []):
        if block.get("type") == "sql":
            sql = block.get("statement", "").strip()
        elif block.get("type") == "text":
            texts.append(block.get("text", ""))
    return sql, " ".join(texts).strip()


_FACT_COL_MAP = {
    "account":         "ACCOUNT",
    "cost_center":     "COST_CENTER",
    "entity":          "ENTITY",
    "functional_area": "FUNCTIONAL_AREA",
    "profit_center":   "PROFIT_CENTER",
