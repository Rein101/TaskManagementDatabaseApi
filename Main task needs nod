def build_filter_cte(filters: dict) -> str:
    wheres: list[str] = []

    hierarchy = filters.get("hierarchy", {})
    for dim, selections in hierarchy.items():
        if not selections:
            continue
        spec = _DIM_HIERARCHY.get(dim)
        if not spec:
            continue
        fact_col = _FACT_COL_MAP[dim]
        dim_wheres = []
        for level_idx, vals in selections.items():
            if vals:
                in_list = ", ".join(f"'{v}'" for v in vals)
                dim_wheres.append(f'{spec["levels"][level_idx]} IN ({in_list})')
        if dim_wheres:
            where_clause = " AND ".join(dim_wheres)
            wheres.append(
                f'{fact_col} IN (SELECT {spec["code_col"]} FROM {spec["table"]} WHERE {where_clause})'
            )

    periods = filters.get("periods", [])
    if periods:
        in_list = ", ".join(f"'{p}'" for p in periods)
        wheres.append(f"TIME IN ({in_list})")

    versions = filters.get("versions", [])
    if versions:
        in_list = ", ".join(f"'{v}'" for v in versions)
        wheres.append(f"VERSION IN ({in_list})")

    return "\n  AND ".join(wheres) if wheres else ""


def inject_filter_clauses(sql: str, filters: dict) -> str:
    if not sql:
        return sql

    where_block = build_filter_cte(filters)
    if not where_block:
        return sql

    table_pattern = r"\b(?:EDW_DEV\.WH\.)?VW_JEDOX_DATA_OPEX\b"
    if not re.search(table_pattern, sql, re.I):
        return sql

    replaced = re.sub(
        r"(?i)(\bFROM\s+)" + r"(?:EDW_DEV\.WH\.)?VW_JEDOX_DATA_OPEX\b",
        r"\1__filtered_fact",
        sql,
    )
    replaced = re.sub(
        r"(?i)(\bJOIN\s+)" + r"(?:EDW_DEV\.WH\.)?VW_JEDOX_DATA_OPEX\b",
        r"\1__filtered_fact",
        replaced,
    )

    if replaced == sql:
        return sql

    our_cte = (
        f"__filtered_fact AS (\n"
        f"  SELECT * FROM EDW_DEV.WH.VW_JEDOX_DATA_OPEX\n"
        f"  WHERE {where_block}\n"
        f")"
    )

    if re.match(r"\s*WITH\b", replaced, re.I):
        replaced = re.sub(r"(?i)^\s*WITH\s+", "", replaced, count=1)
        return f"WITH {our_cte},\n{replaced}"
    else:
        return f"WITH {our_cte}\n{replaced}"


