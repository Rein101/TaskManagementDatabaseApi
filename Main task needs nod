@st.cache_data(ttl=600)
def get_hierarchy_values(dimension: str, level_idx: int, parent_selections: dict) -> list[str]:
    spec = _DIM_HIERARCHY.get(dimension)
    if not spec or level_idx >= len(spec["levels"]):
        return []
    table = spec["table"]
    col = spec["levels"][level_idx]
    wheres = []
    for i in range(level_idx):
        parent_vals = parent_selections.get(i, [])
        if parent_vals:
            in_list = ", ".join(f"'{v}'" for v in parent_vals)
            wheres.append(f'{spec["levels"][i]} IN ({in_list})')
    where_clause = f"WHERE {col} IS NOT NULL AND {col} != ''"
    if wheres:
        where_clause += " AND " + " AND ".join(wheres)
    try:
        df = session.sql(f"SELECT DISTINCT {col} AS VAL FROM {table} {where_clause} ORDER BY 1").to_pandas()
        return df["VAL"].tolist()
    except Exception:
        return []


@st.cache_data(ttl=600)
def get_codes_for_hierarchy(dimension: str, selections: dict) -> list[str]:
    spec = _DIM_HIERARCHY.get(dimension)
    if not spec:
        return []
    table = spec["table"]
    code_col = spec["code_col"]
    wheres = []
    for i, level_col in enumerate(spec["levels"]):
        vals = selections.get(i, [])
        if vals:
            in_list = ", ".join(f"'{v}'" for v in vals)
            wheres.append(f"{level_col} IN ({in_list})")
    if not wheres:
        return []
    where_clause = " AND ".join(wheres)
    try:
        df = session.sql(f"SELECT DISTINCT {code_col} AS VAL FROM {table} WHERE {where_clause} ORDER BY 1").to_pandas()
        return df["VAL"].tolist()
    except Exception:
        return []


def render_cascading_filter(dimension: str, label: str, defaults: dict, key_prefix: str) -> dict:
    spec = _DIM_HIERARCHY[dimension]
    selections = {}
    for level_idx in range(len(spec["levels"])):
        level_label = spec["level_labels"][level_idx]
        opts = get_hierarchy_values(dimension, level_idx, selections)
        if not opts:
            break
        default_vals = defaults.get(level_idx, [])
        valid_defaults = [d for d in default_vals if d in opts]
        selected = st.multiselect(
            f"{label} {level_label}",
            options=opts,
            default=valid_defaults,
            key=f"{key_prefix}_l{level_idx}",
        )
        if selected:
            selections[level_idx] = selected
        else:
            break
    return selections


def build_filtered_question(question: str, filters: dict) -> str:
    parts: list[str] = []

    currency_map = {"EUR": "VAL_EUR", "USD": "VAL_USD_INI", "Local Currency (LC)": "VAL_LC"}
    currency = filters.get("currency", "EUR")
    val_col = currency_map.get(currency, "VAL_EUR")
    parts.append(f"Use {val_col} as the value/amount column (currency: {currency})")

    periods = filters.get("periods", [])
    if periods:
        preview = ", ".join(periods[:8])
        more = f" (+{len(periods)-8} more)" if len(periods) > 8 else ""
        parts.append(f"TIME column IN ({preview}{more}) -- YYYY-MM format")
    versions = filters.get("versions", [])
    if versions:
        parts.append(f"VERSION column IN ({', '.join(versions)})")
    hierarchy = filters.get("hierarchy", {})
    dim_labels = {
        "account": "GL Account",
        "cost_center": "Cost Center",
        "entity": "Entity",
        "functional_area": "Functional Area",
        "profit_center": "Profit Center",
    }
    for dim, selections in hierarchy.items():
        if not selections:
            continue
        spec = _DIM_HIERARCHY[dim]
        label = dim_labels.get(dim, dim)
        deepest_level = max(selections.keys())
        deepest_vals = selections[deepest_level]
        level_name = spec["levels"][deepest_level]
        parts.append(f"{label} hierarchy ({level_name}) IN ({', '.join(deepest_vals)})")
    if not parts:
        return question
    ctx = (
        "MANDATORY FILTERS - You MUST JOIN to dimension tables and apply these WHERE conditions:\n"
        + "\n".join(f"  * {p}" for p in parts)
        + "\n\nDo NOT return data outside these filters."
    )
    return f"{ctx}\n\nQuestion: {question}"


